# Clé API Fantasy (plan Pro) — https://www.fantasyai.cloud/fr/account
FANTASY_API_KEY=
# Endpoint compatible OpenAI (par défaut)
FANTASY_BASE_URL=https://www.fantasyai.cloud/api/v1
# Modèle au choix du catalogue Fantasy (GET /api/v1/models pour la liste)
FANTASY_MODEL=claude-3-5-sonnet-20241022
# Chaîne de modèles de secours (séparés par des virgules) — bascule automatique
# si le modèle principal n'a plus de fournisseur disponible
FANTASY_MODELES_SECOURS=
