  "schema_log_tirage": {
    "description": "Champs à enregistrer pour chaque tirage réel (validation empirique + futur IRIS-Memory)",
    "champs": {
      "id_tirage": "string — identifiant unique",
      "date": "ISO 8601",
      "question": "string — formulation du consultant",
      "spread": "string — ex. cycle-5 (Nœud, Bifurcation, Résonance, Ancrage, Miroir)",
      "cartes_tirees": "array — clés des cartes, dans l'ordre des positions",
      "deck_version": "string — 1.x (original) ou 2.0.0-refonte",
      "dimension_non_couverte": "string|null — aspect de la situation que le deck n'a pas su nommer",
      "carte_forcee": "string|null — clé d'une carte surinterprétée pour coller à la situation",
      "nouvelles_cartes_activees": "array — clés des cartes refonte-v2 apparues",
      "pertinence_ressentie": "integer 1-5 — évaluation du consultant",
      "notes": "string — observations libres"
    }
  }
}
